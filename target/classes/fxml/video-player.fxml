<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.media.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="ui.controllers.VideoPlayerController"
      styleClass="main-root" stylesheets="@../styles/youtube-style.css"
      spacing="0" prefHeight="800.0" prefWidth="1200.0">
    
    <!-- Header/Back Button -->
    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="20">
        <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
        </padding>
        <children>
            <Button text="← Back" styleClass="nav-button" onAction="#handleBack" />
            <Text fx:id="videoTitleText" fill="WHITE" styleClass="page-title" text="Video Title" />
        </children>
    </HBox>

    <HBox VBox.vgrow="ALWAYS" spacing="20">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
        <children>
            <!-- Player Section -->
            <VBox HBox.hgrow="ALWAYS" spacing="15">
                <children>
                    <StackPane fx:id="playerContainer" styleClass="glass-panel" style="-fx-background-color: black;">
                        <MediaView fx:id="mediaView" fitHeight="500.0" fitWidth="800.0" />
                        
                        <!-- Loading Overlay -->
                        <VBox fx:id="loadingOverlay" alignment="CENTER" visible="false">
                            <ProgressIndicator prefHeight="60.0" prefWidth="60.0" />
                            <Label text="Buffering..." textFill="WHITE" />
                        </VBox>
                    </StackPane>

                    <!-- Controls -->
                    <VBox styleClass="glass-panel" spacing="10">
                        <padding>
                            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                        </padding>
                        <children>
                            <Slider fx:id="seekSlider" maxWidth="Infinity" />
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <children>
                                    <Button fx:id="playPauseBtn" text="Play" styleClass="nav-button" onAction="#togglePlay" />
                                    <Label fx:id="timeLabel" text="0:00 / 0:00" textFill="WHITE" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Volume" textFill="WHITE" />
                                    <Slider fx:id="volumeSlider" prefWidth="100.0" value="50.0" />
                                    <Button text="⛶ Fullscreen" styleClass="nav-button" onAction="#toggleFullscreen" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <VBox spacing="5">
                        <Text fx:id="videoFullTitle" fill="WHITE" style="-fx-font-size: 24; -fx-font-weight: bold;" text="Title" />
                        <Text fx:id="videoDesc" fill="LIGHTGRAY" wrappingWidth="800" text="Description goes here..." />
                    </VBox>
                </children>
            </VBox>

            <!-- Sidebar (Up Next) -->
            <VBox prefWidth="400" spacing="10" style="-fx-background-color: #0F0F0F;">
                <padding>
                    <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                </padding>
                <children>
                    <Text fill="WHITE" text="Up Next" style="-fx-font-size: 18; -fx-font-weight: bold;" />
                    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS" hbarPolicy="NEVER">
                        <content>
                            <VBox fx:id="recommendationList" spacing="4">
                                <!-- Recommended videos will be here -->
                            </VBox>
                        </content>
                    </ScrollPane>
                </children>
            </VBox>
        </children>
    </HBox>
</VBox>
