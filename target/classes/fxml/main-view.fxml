<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ui.controllers.MainViewController"
            styleClass="main-root"
            stylesheets="@../styles/youtube-style.css">

    <!-- ======================== TOP HEADER ======================== -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <!-- Left: Menu & Logo -->
            <HBox spacing="16" alignment="CENTER_LEFT" prefWidth="240" minWidth="200">
                <padding><Insets left="16"/></padding>
                <Button text="≡" styleClass="icon-btn" style="-fx-font-size: 24px;"/>
                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="▶" styleClass="logo-icon"/>
                    <Label text="YouTube" styleClass="logo-label"/>
                    <Label text="ET" style="-fx-text-fill: #AAAAAA; -fx-font-size: 10px; -fx-padding: 0 0 10 2;"/>
                </HBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Center: Search -->
            <HBox alignment="CENTER" spacing="0" HBox.hgrow="NEVER" maxWidth="600">
                <TextField fx:id="searchField" promptText="Search"
                           styleClass="search-bar" onAction="#handleSearch"/>
                <Button text="🔍" styleClass="search-btn" onAction="#handleSearch"/>
                <Region prefWidth="16"/>
                <Button text="🎙" styleClass="icon-btn" style="-fx-background-color: #181818;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Right: Actions -->
            <HBox spacing="12" alignment="CENTER_RIGHT" prefWidth="280" minWidth="220">
                <padding><Insets right="16"/></padding>
                <Button text="＋ Create" styleClass="upload-btn-youtube" onAction="#handleUpload"/>
                <Button text="🔔" styleClass="icon-btn"/>
                <Button text="👤" styleClass="icon-btn"/>
            </HBox>
        </HBox>
    </top>

    <!-- ======================== SIDEBAR ======================== -->
    <left>
        <VBox styleClass="sidebar" prefWidth="200" spacing="2">
            <padding><Insets top="12" right="4" bottom="12" left="4"/></padding>

            <Button text="🏠  Home"       styleClass="nav-btn, nav-btn-active" onAction="#handleHome"   maxWidth="Infinity"/>
            <Button text="🎞️  Shorts"     styleClass="nav-btn"                 onAction="#handleHome"   maxWidth="Infinity"/>
            <Button text="📋  Subscriptions" styleClass="nav-btn"              onAction="#handleHome"   maxWidth="Infinity"/>

            <Separator style="-fx-padding: 12 16; -fx-opacity: 0.1;"/>

            <Label text="You >" styleClass="sidebar-section-label" style="-fx-font-size: 14px; -fx-padding: 0 16;"/>
            <Button text="📚  History"    styleClass="nav-btn" maxWidth="Infinity"/>
            <Button text="🕓  Watch Later" styleClass="nav-btn" maxWidth="Infinity"/>
            <Button text="👍  Liked videos" styleClass="nav-btn" maxWidth="Infinity"/>

            <Separator style="-fx-padding: 12 16; -fx-opacity: 0.1;"/>

            <!-- SERVER STATUS -->
            <VBox spacing="8" style="-fx-padding: 12 16;">
                <Label text="Node Status" styleClass="sidebar-section-label" style="-fx-font-size: 12px; -fx-padding: 0;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label fx:id="node1StatusDot" text="●" styleClass="status-dot-red"/>
                    <Label text="Node 1 (1099)" styleClass="status-text"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label fx:id="node2StatusDot" text="●" styleClass="status-dot-red"/>
                    <Label text="Node 2 (1100)" styleClass="status-text"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ======================== MAIN CONTENT ======================== -->
    <center>
        <VBox>
            <ScrollPane fx:id="scrollPane" styleClass="main-scroll"
                        fitToWidth="true" VBox.vgrow="ALWAYS">
                <content>
                    <VBox spacing="0">
                        <!-- Alerts -->
                        <HBox fx:id="alertBox" visible="false" managed="false"
                               alignment="CENTER_LEFT" style="-fx-padding: 12 24;">
                            <Label fx:id="alertLabel" text="" wrapText="true" style="-fx-text-fill: white; -fx-background-color: #272727; -fx-padding: 12; -fx-background-radius: 8;"/>
                        </HBox>

                        <Label fx:id="pageTitleLabel" text="All" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 12 24 0 24;"/>

                        <!-- Empty State -->
                        <VBox fx:id="emptyState" alignment="CENTER" spacing="16"
                               style="-fx-padding: 140 0;">
                            <Label text="📹" style="-fx-font-size: 100px; -fx-opacity: 0.2;"/>
                            <Label text="No videos found" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                            <Label text="Try searching for something else or upload a video."
                                   style="-fx-text-fill: #AAAAAA; -fx-font-size: 14px;"/>
                        </VBox>

                        <!-- Video Grid -->
                        <FlowPane fx:id="videoGrid"
                                  hgap="16" vgap="32"
                                  styleClass="video-grid">
                        </FlowPane>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- STATUS BAR -->
            <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="16">
                <Label fx:id="statusLabel" text="Connected" styleClass="status-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="videoCountLabel" text="0 videos" styleClass="status-text"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
